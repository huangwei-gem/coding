# ===========================================
# 发票收集自动化系统 - 配置文件模板
# 复制此文件为 .env 并填入真实配置
# ===========================================

# ----- 数据库配置 -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=invoice_project

# ----- 短信服务商配置（以阿里云为例）-----
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your_access_key_id
SMS_ACCESS_KEY_SECRET=your_access_key_secret
SMS_SIGN_NAME=你的签名
SMS_TEMPLATE_CODE=SMS_123456789
# 优先用 template，如不支持则用此自定义内容（支持变量 {name} {building} {room}）
SMS_CUSTOM_CONTENT=尊敬的{name}业主您好，关于小区居委会换届事宜，请您回复"同意"或"不同意"确认您的意愿。感谢您的支持！

# ----- AI API 配置（用于情绪分析+意愿判断）-----
AI_API_KEY=your_openai_api_key
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ----- 系统运行模式 -----
# demo: 模拟模式（不真实发短信、不连真实数据库）
# production: 生产模式
RUN_MODE=demo
